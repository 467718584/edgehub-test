const WebSocket = require('ws');

const deviceClients = new Map();
const agentClients = new Set();

function initWebSocket(server) {
  const wss = new WebSocket.Server({ noServer: true });

  // Handle HTTP Upgrade for /ws path
  server.on('upgrade', (req, socket, head) => {
    const url = new URL(req.url, `http://${req.headers.host}`);
    if (url.pathname === '/ws') {
      wss.handleUpgrade(req, socket, head, (ws) => {
        wss.emit('connection', ws, req);
      });
    } else {
      socket.destroy();
    }
  });

  const heartbeatInterval = setInterval(() => {
    wss.clients.forEach((ws) => {
      if (ws.isAlive === false) {
        for (const [deviceId, client] of deviceClients.entries()) {
          if (client === ws) {
            deviceClients.delete(deviceId);
            // Mark device as offline when WS connection dies
            if (global.db) {
              global.db.updateDeviceStatus(deviceId, 'offline').catch(() => {});
            }
            break;
          }
        }
        return ws.terminate();
      }
      ws.isAlive = false;
      ws.send(JSON.stringify({ type: 'ping', request_sysinfo: true }));
    });
  }, 60000);

  wss.on('close', () => clearInterval(heartbeatInterval));

  wss.on('connection', (ws, req) => {
    ws.isAlive = true;
    const url = new URL(req.url, 'http://localhost');

// Convert EdgeAgent sysinfo to Web panel format
function convertSysinfo(sysinfo) {
  if (!sysinfo) return null;
  return {
    cpu: { usage: 0, cores: 0, model: sysinfo.platform || '-' },
    memory: { percent: 0, used: 0, total: 0 },
    disk: { percent: 0, used: 0, total: 0 },
    load: { '1min': sysinfo.load_1min || 0, '5min': sysinfo.load_5min || 0, '15min': sysinfo.load_15min || 0 },
    uptime: sysinfo.uptime || 0,
    platform: sysinfo.platform || '-',
    python: sysinfo.python || '-'
  };
}


    const deviceId = url.searchParams.get('device_id');
    const apiKey = url.searchParams.get('api_key');
    const clientType = url.searchParams.get('type') || 'device';

    console.log('[WS] New connection:', { deviceId, clientType });

    if (clientType === 'device') {
      if (apiKey !== 'edgehub_secret_key') {
        ws.close(4001, 'Invalid API key'); return;
      }
      if (!deviceId) { ws.close(4002, 'Missing device_id'); return; }
      
      deviceClients.set(deviceId, ws);
      console.log('[WS] Device connected:', deviceId);
      ws.send(JSON.stringify({ type: 'connected', device_id: deviceId }));
      
      // Update device status to online when WS connects
      if (global.db) {
        global.db.updateDeviceStatus(deviceId, 'online').catch(() => {});
      }
    } else {
      agentClients.add(ws);
    }

    ws.on('message', async (data) => {
      try {
        console.log("[WS] RX:", data.toString().substring(0, 200)); let msgStr = typeof data === "string" ? data : (data instanceof Buffer ? data.toString() : String(data)); const msg = JSON.parse(msgStr); console.log("[WS] msg.type:", msg.type, "msg:", JSON.stringify(msg).substring(0,100));
        if (msg.type === 'ping') {
          ws.send(JSON.stringify({ type: 'pong' }));
          // Heartbeat ping - update device last_heartbeat
          if (deviceId && global.db) {
            global.db.updateDeviceStatus(deviceId, 'online').catch(() => {});
          }
        } else if (msg.type === 'pong') {
          // Client responded to our heartbeat ping
          ws.isAlive = true;
          if (deviceId && global.db) {
            global.db.updateHeartbeat(deviceId).catch(() => {});
          }
        } else if (msg.type === 'heartbeat') {
          // Device heartbeat via WebSocket - update last_heartbeat and sysinfo
          ws.send(JSON.stringify({ type: 'pong' }));
          if (deviceId && global.db) {
            const sysinfo = msg.sysinfo ? JSON.stringify(msg.sysinfo) : null;
            global.db.updateHeartbeat(deviceId, { sysinfo }).catch(() => {});
            global.db.updateDeviceStatus(deviceId, 'online').catch(() => {});
          }
          broadcastToAgents({ type: 'device_heartbeat', device_id: deviceId, ...msg });
        } else if (msg.type === "command_result") { console.log("[WS] command_result detected!"); 
          // Device reported command result - update DB
          // EdgeAgent sends: { type, commandId, deviceId, exit_code, output, error }
          const cmdId = msg.commandId || msg.command_id;
          console.log("[WS] Handling command_result, global.db:", typeof global.db, "cmdId:", cmdId); if (global.db && cmdId) {
            const exitCode = msg.exit_code ?? (msg.success ? 0 : -1);
            const status = exitCode === 0 ? 'completed' : 'failed';
            global.db.updateCommandStatus(cmdId, status, {
              stdout: msg.stdout || msg.output || '',
              stderr: msg.stderr || msg.error || '',
              exit_code: exitCode,
              duration_ms: msg.duration_ms || 0
            }).catch(e => console.log('[WS] Failed to update command result:', e.message));
          }
          broadcastToAgents({ type: 'command_result', device_id: deviceId, ...msg });
        } else if (msg.type === 'device_status') {
          // Device reported sysinfo - update database
          if (global.db && msg.sysinfo) {
            global.db.updateHeartbeat(deviceId, {sysinfo: JSON.stringify(convertSysinfo(msg.sysinfo))}).catch(e => console.log('[WS] sysinfo update failed:', e.message));
          }
          broadcastToAgents({ type: 'device_status_update', device_id: deviceId, ...msg });
        }
      } catch (e) {
        ws.send(JSON.stringify({ type: 'error', message: e.message }));
      }
    });

    ws.on('pong', () => { ws.isAlive = true; if (deviceId && global.db) { global.db.updateHeartbeat(deviceId).catch(() => {}); } });
    ws.on('close', () => {
      console.log('[WS] Device disconnected:', deviceId);
      if (deviceId) {
        deviceClients.delete(deviceId);
        // Mark device offline when WS connection closes
        if (global.db) {
          global.db.updateDeviceStatus(deviceId, 'offline').catch(() => {});
        }
      }
      agentClients.delete(ws);
    });
  });

  console.log('[WS] WebSocket server initialized on /ws');
  return wss;
}

function broadcastToAgents(message) {
  const msgStr = JSON.stringify(message);
  agentClients.forEach((ws) => {
    if (ws.readyState === WebSocket.OPEN) ws.send(msgStr);
  });
}

// Push command to device via WebSocket (WS mode - primary)
async function pushCommandToDevice(deviceId, command) {
  const ws = deviceClients.get(deviceId);
  if (!ws || ws.readyState !== WebSocket.OPEN) {
    return { success: false, error: 'Device not connected via WS' };
  }
  // 统一格式: type=command, data内字段使用snake_case，单位为毫秒
  ws.send(JSON.stringify({
    type: 'command',
    data: {
      command_id: command.command_id,
      command: command.command,
      timeout_ms: command.timeout_ms || 30000
    }
  }));
  return { success: true };
}

// Export deviceClients map for command queue service to check connection status
function getDeviceClient(deviceId) {
  return deviceClients.get(deviceId);
}

function isDeviceConnected(deviceId) {
  const ws = deviceClients.get(deviceId);
  return ws && ws.readyState === WebSocket.OPEN;
}

module.exports = { initWebSocket, pushCommandToDevice, broadcastToAgents, getDeviceClient, isDeviceConnected, deviceClients };